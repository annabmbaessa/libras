<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Voz → Libras</title>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    font-family: Arial, sans-serif;
    background: linear-gradient(135deg, #0f172a, #1e3a8a);
    color:white;
}

/* LADO ESQUERDO */
.left{
    flex:1;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
}

.mic{
    width:160px;
    height:160px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#111;
    cursor:pointer;
    transition:0.3s;
    box-shadow: 0 0 20px rgba(255,255,255,0.1);
}

.mic.ativo{
    box-shadow: 0 0 40px #22c55e;
    transform: scale(1.05);
}

.mic img{
    width:80px;
}

.status{
    margin-top:20px;
    font-size:1.2rem;
    opacity:0.8;
}

/* LADO DIREITO */
.right{
    flex:1;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
}

.box{
    width:350px;
    height:350px;
    border:3px solid #fbbf24;
    display:flex;
    align-items:center;
    justify-content:center;
    position:relative;
}

/* LEGENDA */
#legenda{
    position:absolute;
    bottom:-80px;
    background: rgba(0,0,0,0.7);
    padding:10px 20px;
    border-radius:10px;
    max-width:300px;
    text-align:center;
    opacity:0;
    transition:0.3s;
}

#legenda.show{
    opacity:1;
}

/* VLibras: permite clique apenas nos botões e wrapper */
[vw] {
    pointer-events: auto;
}

[vw] > * {
    pointer-events: none;
}

[vw-access-button],
.vw-plugin-wrapper {
    pointer-events: auto;
}
</style>
</head>

<body>

<div class="left">
    <div id="mic" class="mic">
        <img src="https://cdn-icons-png.flaticon.com/512/61/61088.png">
    </div>

    <div id="status" class="status">Clique no microfone para iniciar</div>
</div>

<div class="right">
    <div class="box">
        <div id="legenda"></div>
    </div>
</div>

<!-- VLibras -->
<div vw class="enabled">
  <div vw-access-button class="active"></div>
  <div vw-plugin-wrapper>
    <div class="vw-plugin-top-wrapper"></div>
  </div>
</div>

<script src="https://vlibras.gov.br/app/vlibras-plugin.js"></script>

<script>
new window.VLibras.Widget('https://vlibras.gov.br/app');

const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
const recognition = new SpeechRecognition();

recognition.lang = "pt-BR";
recognition.continuous = true;
recognition.interimResults = true;

let ativo = false;
let timeoutLegenda;

const mic = document.getElementById("mic");
const status = document.getElementById("status");

// 🔥 CLICK NO MICROFONE
mic.onclick = () => {
    if(!ativo){
        recognition.start();
        ativo = true;
        status.innerText = "Microfone ativo";
        mic.classList.add("ativo");
    } else {
        recognition.stop();
        ativo = false;
        status.innerText = "Microfone desligado";
        mic.classList.remove("ativo");
    }
};

// VOZ → TEXTO
recognition.onresult = (event) => {
    let textoFinal = "";
    let textoParcial = "";

    for(let i = event.resultIndex; i < event.results.length; i++){
        let transcript = event.results[i][0].transcript;

        if(event.results[i].isFinal){
            textoFinal += transcript + " ";
        } else {
            textoParcial += transcript;
        }
    }

    let texto = (textoFinal + textoParcial).trim();

    if(texto.length > 0){
        mostrarLegenda(texto);
    }
};

// MOSTRAR LEGENDA
function mostrarLegenda(texto){
    const legenda = document.getElementById("legenda");

    legenda.innerText = texto;
    legenda.classList.add("show");

    clearTimeout(timeoutLegenda);
    timeoutLegenda = setTimeout(()=>{
        legenda.classList.remove("show");
    },4000);

    // força VLibras ler só isso
    setTimeout(() => {
        legenda.click();
    },100);
}

// CONTROLE
recognition.onend = () => {
    if(ativo){
        setTimeout(()=>{
            if(ativo) recognition.start();
        },200);
    }
};

// ERROS
recognition.onerror = (event) => {
    console.error(event.error);

    if(event.error === "not-allowed" || event.error === "not-found"){
        alert("Microfone não disponível ou bloqueado");
        ativo = false;
        status.innerText = "Microfone desligado";
        mic.classList.remove("ativo");
    }
};
</script>

</body>
</html>
